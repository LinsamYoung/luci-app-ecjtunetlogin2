#!/bin/sh /etc/rc.common

START=99
STOP=10
USE_PROCD=1

PROG=/usr/bin/ecjtunetlogin2
LOG=/tmp/ecjtunetlogin2.log

start_service() {
    touch "$LOG" 2>/dev/null
    procd_open_instance
    procd_set_param command "$PROG"
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param respawn
    procd_close_instance
}

stop_service() {
    killall -TERM ecjtunetlogin2 2>/dev/null
}
